<fieldset>
  {{formGroup name.field value=name.value label=name.label name="name" placeholder=(localize "Name")}}
  {{formInput description.field value=description.value enriched=description.enriched name="description" height=300}}
  <div class="form-group">
    <label>Value</label>
    <div class="form-fields">
      {{formInput value.field value=value.value name="config.value" placeholder="0"}}
      <span class="sep">/</span>
      {{formInput max.field value=max.value name="config.max" placeholder="20"}}
    </div>
  </div>
</fieldset>
